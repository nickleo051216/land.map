<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>土地實價地籍圖 | ZN Studio</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;600;700&display=swap');
  *{margin:0;padding:0;box-sizing:border-box;}
  :root{
    --bg:#0a0f1a;--card:#111827;--card2:#1a2332;
    --border:rgba(99,179,237,.15);--accent:#63b3ed;--glow:rgba(99,179,237,.25);
    --t1:#e8edf5;--t2:#94a3b8;--t3:#64748b;
    --hi:#f56565;--mid:#ecc94b;--lo:#48bb78;--land:#b794f4;
  }
  body{font-family:'Noto Sans TC',sans-serif;background:var(--bg);color:var(--t1);height:100vh;overflow:hidden;}
  .app{display:grid;grid-template-columns:340px 1fr;grid-template-rows:auto 1fr;height:100vh;}
  .hdr{grid-column:1/-1;background:linear-gradient(135deg,#1a365d,#0d1b2a);border-bottom:1px solid var(--border);padding:12px 20px;display:flex;align-items:center;justify-content:space-between;}
  .hdr .left{display:flex;align-items:center;gap:12px;}
  .hdr .logo{width:36px;height:36px;background:linear-gradient(135deg,var(--accent),#4299e1);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:700;color:#fff;box-shadow:0 4px 16px var(--glow);}
  .hdr h1{font-size:15px;font-weight:600;}
  .hdr .sub{font-size:11px;color:var(--t2);}
  .hdr .right{font-size:11px;color:var(--t3);text-align:right;line-height:1.5;}
  .hdr .right a{color:var(--accent);text-decoration:none;}
  .hdr .badge{background:rgba(99,179,237,.1);border:1px solid var(--border);border-radius:20px;padding:3px 12px;font-size:10px;color:var(--accent);margin-right:12px;}

  .side{background:var(--card);border-right:1px solid var(--border);overflow-y:auto;display:flex;flex-direction:column;}
  .sec{padding:14px;border-bottom:1px solid var(--border);}
  .sec h3{font-size:11px;font-weight:600;color:var(--t2);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:10px;}
  .search{display:flex;align-items:center;background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:8px 12px;gap:8px;}
  .search input{flex:1;background:none;border:none;color:var(--t1);font-size:13px;outline:none;font-family:inherit;}
  .search input::placeholder{color:var(--t3);}

  .layer{display:flex;align-items:center;justify-content:space-between;padding:8px 0;cursor:pointer;}
  .layer .lbl{display:flex;align-items:center;gap:8px;font-size:13px;}
  .layer .dot{width:10px;height:10px;border-radius:50%;}
  .tog{width:36px;height:20px;border-radius:10px;background:#334155;position:relative;transition:.3s;}
  .tog.on{background:var(--accent);}
  .tog::after{content:'';position:absolute;top:2px;left:2px;width:16px;height:16px;border-radius:50%;background:#fff;transition:.3s;}
  .tog.on::after{left:18px;}

  .stats{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px;}
  .stat{background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:10px;text-align:center;}
  .stat .v{font-size:22px;font-weight:700;}
  .stat .l{font-size:10px;color:var(--t3);margin-top:2px;}

  .query-info{background:rgba(99,179,237,.08);border:1px solid var(--border);border-radius:8px;padding:12px;margin-bottom:8px;font-size:12px;line-height:1.7;}
  .query-info .qi-title{font-weight:600;color:var(--accent);margin-bottom:4px;font-size:13px;}

  .cards{flex:1;overflow-y:auto;}
  .card{padding:12px 14px;border-bottom:1px solid var(--border);cursor:pointer;transition:.2s;}
  .card:hover{background:var(--card2);}
  .card .top{display:flex;justify-content:space-between;align-items:center;}
  .card .addr{font-size:13px;font-weight:500;flex:1;}
  .card .pr{font-size:14px;font-weight:700;white-space:nowrap;}
  .card .pr.hi{color:var(--hi);} .card .pr.mid{color:var(--mid);} .card .pr.lo{color:var(--lo);} .card .pr.ld{color:var(--land);}
  .card .meta{display:flex;gap:6px;margin-top:6px;flex-wrap:wrap;}
  .card .tag{background:rgba(148,163,184,.1);border:1px solid rgba(148,163,184,.15);border-radius:4px;padding:1px 7px;font-size:10px;color:var(--t2);}

  .map-wrap{position:relative;}
  #map{width:100%;height:100%;}
  .legend{position:absolute;bottom:20px;left:20px;background:var(--card);border:1px solid var(--border);border-radius:10px;padding:12px 16px;z-index:999;font-size:11px;}
  .legend h5{color:var(--t2);margin-bottom:8px;font-size:10px;text-transform:uppercase;letter-spacing:1px;}
  .legend .li{display:flex;align-items:center;gap:8px;margin:4px 0;}
  .legend .ci{width:12px;height:12px;border-radius:50%;border:2px solid;}

  .loading{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:var(--card);border:1px solid var(--border);border-radius:12px;padding:24px 36px;z-index:1000;text-align:center;display:none;}
  .loading.show{display:block;}
  .loading .spinner{width:30px;height:30px;border:3px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin 1s linear infinite;margin:0 auto 10px;}
  @keyframes spin{to{transform:rotate(360deg);}}

  .foot{padding:10px 14px;background:var(--bg);border-top:1px solid var(--border);text-align:center;font-size:10px;color:var(--t3);line-height:1.6;}
  .foot a{color:var(--accent);text-decoration:none;}

  .leaflet-popup-content-wrapper{background:var(--card)!important;color:var(--t1)!important;border:1px solid var(--border)!important;border-radius:10px!important;box-shadow:0 8px 30px rgba(0,0,0,.4)!important;}
  .leaflet-popup-tip{background:var(--card)!important;}
  .pop-title{font-weight:600;font-size:14px;margin-bottom:8px;color:var(--accent);}
  .pop-row{display:flex;justify-content:space-between;padding:3px 0;font-size:12px;border-bottom:1px solid rgba(255,255,255,.05);}
  .pop-lbl{color:var(--t3);}
  .pop-val{font-weight:500;}
  .pop-price{margin-top:8px;font-size:15px;font-weight:700;text-align:center;padding:6px;border-radius:6px;background:rgba(99,179,237,.1);}

  @media(max-width:768px){
    .app{grid-template-columns:1fr;grid-template-rows:auto 50vh 1fr;}
    .side{order:3;} .hdr .right{display:none;}
  }
</style>
</head>
<body>
<div class="app">
  <div class="hdr">
    <div class="left">
      <div class="logo">ZN</div>
      <div>
        <h1>土地實價 × 地籍圖 分析系統</h1>
        <div class="sub">Land Price Analysis with Cadastral Map — n8n Automation</div>
      </div>
    </div>
    <div class="right">
      <span class="badge">高雄市</span>
      Nick Chang｜<a href="mailto:nickleo051216@gmail.com">nickleo051216@gmail.com</a>｜0932-684-051<br>
      <a href="https://portaly.cc/zn.studio" target="_blank">ZN Studio</a>｜
      <a href="https://www.threads.com/@nickai216" target="_blank">@nickai216</a>｜
      <a href="https://lin.ee/Faz0doj" target="_blank">LINE</a>
    </div>
  </div>

  <div class="side">
    <div class="sec">
      <h3>搜尋地段</h3>
      <div class="search">
        <span>🔍</span>
        <input type="text" id="searchInput" placeholder="輸入地段或地號，例如：溪洲段..." oninput="filterData(this.value)">
      </div>
    </div>

    <div class="sec" id="queryInfoSec" style="display:none;">
      <div class="query-info" id="queryInfo"></div>
    </div>

    <div class="sec">
      <h3>圖層控制</h3>
      <div class="layer" onclick="toggleLayer('luimap')">
        <div class="lbl"><div class="dot" style="background:#f6ad55;"></div><span>國土利用圖（分區顏色）</span></div>
        <div class="tog on" id="tog-luimap"></div>
      </div>
      <div class="layer" onclick="toggleLayer('cadastral')">
        <div class="lbl"><div class="dot" style="background:#63b3ed;"></div><span>地籍圖（地號邊界）</span></div>
        <div class="tog on" id="tog-cadastral"></div>
      </div>
      <div class="layer" onclick="toggleLayer('emap')">
        <div class="lbl"><div class="dot" style="background:#68d391;"></div><span>電子地圖（路名）</span></div>
        <div class="tog on" id="tog-emap"></div>
      </div>
      <div class="layer" onclick="toggleLayer('photo')">
        <div class="lbl"><div class="dot" style="background:#b794f4;"></div><span>正射影像（衛星）</span></div>
        <div class="tog" id="tog-photo"></div>
      </div>
      <div class="layer" onclick="toggleLayer('markers')">
        <div class="lbl"><div class="dot" style="background:#fc8181;"></div><span>成交標記</span></div>
        <div class="tog on" id="tog-markers"></div>
      </div>
    </div>

    <div class="sec">
      <h3>區域統計</h3>
      <div class="stats">
        <div class="stat"><div class="v" id="s-count">0</div><div class="l">成交筆數</div></div>
        <div class="stat"><div class="v" id="s-avg">-</div><div class="l">平均單價(萬/坪)</div></div>
        <div class="stat"><div class="v" id="s-hi" style="color:var(--hi);">-</div><div class="l">最高單價</div></div>
        <div class="stat"><div class="v" id="s-lo" style="color:var(--lo);">-</div><div class="l">最低單價</div></div>
      </div>
    </div>

    <div class="sec"><h3>土地成交資料</h3></div>
    <div class="cards" id="cardList"></div>

    <div class="foot">
      <a href="https://portaly.cc/zn.studio" target="_blank">ZN Studio</a>
      ・<a href="https://lin.ee/Faz0doj" target="_blank">LINE 官方帳號</a>
      ・<a href="https://reurl.cc/1OZNAY" target="_blank">LINE 社群</a>
      <br>Nick Chang｜nickleo051216@gmail.com｜0932-684-051
    </div>
  </div>

  <div class="map-wrap">
    <div id="map"></div>
    <div class="legend">
      <h5>土地單價 (萬/坪)</h5>
      <div class="li"><div class="ci" style="background:rgba(245,101,101,.3);border-color:#f56565;"></div>20 萬以上</div>
      <div class="li"><div class="ci" style="background:rgba(236,201,75,.3);border-color:#ecc94b;"></div>10 ~ 20 萬</div>
      <div class="li"><div class="ci" style="background:rgba(72,187,120,.3);border-color:#48bb78;"></div>10 萬以下</div>
      <div class="li"><div class="ci" style="background:rgba(183,148,244,.3);border-color:#b794f4;border-radius:3px;"></div>查詢目標</div>
    </div>
    <div class="loading" id="loading"><div class="spinner"></div>載入資料中...</div>
  </div>
</div>

<script>
// === URL 參數解析 ===
const params = new URLSearchParams(window.location.search);
const qLat = parseFloat(params.get('lat')) || 22.505;
const qLng = parseFloat(params.get('lng')) || 120.395;
const qSection = decodeURIComponent(params.get('section') || '');
const qDistrict = decodeURIComponent(params.get('district') || '林園區');
const qLandNum = decodeURIComponent(params.get('landNumber') || '');
// n8n Webhook URL for fetching data (optional)
const apiUrl = params.get('api') || '';

let allData = [];

// === 地圖初始化 ===
const map = L.map('map', { center: [qLat, qLng], zoom: 16, zoomControl: true });

const osmBase = L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
  maxZoom: 20, attribution: '&copy; OSM &copy; CARTO'
}).addTo(map);

const emapLayer = L.tileLayer('https://wmts.nlsc.gov.tw/wmts/EMAP/default/GoogleMapsCompatible/{z}/{y}/{x}', {
  maxZoom: 20, opacity: 0.3, attribution: '&copy; NLSC 電子地圖'
}).addTo(map);

const luimapLayer = L.tileLayer.wms('https://wms.nlsc.gov.tw/wms', {
  layers: 'LUIMAP', format: 'image/png', transparent: true, opacity: 0.5, maxZoom: 20,
  attribution: '&copy; NLSC 國土利用圖'
}).addTo(map);

const cadastralLayer = L.tileLayer.wms('https://wms.nlsc.gov.tw/wms', {
  layers: 'LANDSECT', format: 'image/png', transparent: true, opacity: 0.6, maxZoom: 20,
  attribution: '&copy; NLSC 地籍圖'
}).addTo(map);

const photoLayer = L.tileLayer('https://wmts.nlsc.gov.tw/wmts/PHOTO2/default/GoogleMapsCompatible/{z}/{y}/{x}', {
  maxZoom: 20, opacity: 0.5, attribution: '&copy; NLSC 正射影像'
});

const layers = {
  luimap: { layer: luimapLayer, active: true },
  cadastral: { layer: cadastralLayer, active: true },
  emap: { layer: emapLayer, active: true },
  photo: { layer: photoLayer, active: false },
  markers: { active: true }
};

// === 查詢目標標記 ===
const targetIcon = L.divIcon({
  className: 'custom-marker',
  html: `<div style="width:20px;height:20px;background:var(--land);border:3px solid #fff;border-radius:4px;box-shadow:0 0 15px rgba(183,148,244,.6),0 0 30px rgba(183,148,244,.3);"></div>`,
  iconSize: [20, 20], iconAnchor: [10, 10]
});
const targetMarker = L.marker([qLat, qLng], { icon: targetIcon }).addTo(map);
targetMarker.bindPopup(`
  <div class="pop-title">📍 查詢目標</div>
  <div class="pop-row"><span class="pop-lbl">行政區</span><span class="pop-val">${qDistrict}</span></div>
  ${qSection ? `<div class="pop-row"><span class="pop-lbl">地段</span><span class="pop-val">${qSection}</span></div>` : ''}
  ${qLandNum ? `<div class="pop-row"><span class="pop-lbl">地號</span><span class="pop-val">${qLandNum}</span></div>` : ''}
`).openPopup();

// 顯示查詢資訊
if (qSection || qDistrict) {
  document.getElementById('queryInfoSec').style.display = 'block';
  document.getElementById('queryInfo').innerHTML = `
    <div class="qi-title">📍 查詢資訊</div>
    ${qDistrict ? '行政區：<strong>' + qDistrict + '</strong><br>' : ''}
    ${qSection ? '地段：<strong>' + qSection + '</strong><br>' : ''}
    ${qLandNum ? '地號：<strong>' + qLandNum + '</strong><br>' : ''}
    座標：${qLat.toFixed(5)}, ${qLng.toFixed(5)}
  `;
}

// === 標記群組 ===
const markerGroup = L.layerGroup().addTo(map);

function getColor(p) { return p >= 20 ? '#f56565' : p >= 10 ? '#ecc94b' : '#48bb78'; }
function getPrCls(p) { return p >= 20 ? 'hi' : p >= 10 ? 'mid' : 'lo'; }

function createMarkers(data) {
  markerGroup.clearLayers();
  data.forEach((d, i) => {
    if (!d.lat || !d.lng || d.lat === 0) return;
    const color = getColor(d.unitPrice);
    const icon = L.divIcon({
      className: 'custom-marker',
      html: `<div style="width:14px;height:14px;background:${color};border:2px solid #fff;border-radius:50%;box-shadow:0 0 10px ${color}80;"></div>`,
      iconSize: [14, 14], iconAnchor: [7, 7]
    });
    const popup = `
      <div class="pop-title">${d.section || ''}${d.landNumber || ''}</div>
      <div class="pop-row"><span class="pop-lbl">行政區</span><span class="pop-val">${d.district || ''}</span></div>
      <div class="pop-row"><span class="pop-lbl">地段</span><span class="pop-val">${d.section || ''}</span></div>
      <div class="pop-row"><span class="pop-lbl">地號</span><span class="pop-val">${d.landNumber || ''}</span></div>
      <div class="pop-row"><span class="pop-lbl">面積</span><span class="pop-val">${d.area || '?'} 坪</span></div>
      <div class="pop-row"><span class="pop-lbl">分區</span><span class="pop-val">${d.zoning || ''}</span></div>
      <div class="pop-row"><span class="pop-lbl">日期</span><span class="pop-val">${d.date || ''}</span></div>
      <div class="pop-price" style="color:${color};">
        總價 ${d.totalPrice || '?'} 萬　|　單價 ${d.unitPrice || '?'} 萬/坪
      </div>
    `;
    markerGroup.addLayer(L.marker([d.lat, d.lng], { icon }).bindPopup(popup, { maxWidth: 280 }));
  });
}

function renderCards(data) {
  document.getElementById('cardList').innerHTML = data.map((d, i) => `
    <div class="card" onclick="flyTo(${d.lat},${d.lng})">
      <div class="top">
        <div class="addr">${d.section || ''}${d.landNumber ? ' ' + d.landNumber : ''}</div>
        <div class="pr ${getPrCls(d.unitPrice)}">${d.unitPrice || '?'}萬/坪</div>
      </div>
      <div class="meta">
        <span class="tag">${d.district || ''}</span>
        <span class="tag">${d.area || '?'}坪</span>
        <span class="tag">${d.zoning || ''}</span>
        <span class="tag">${d.date || ''}</span>
      </div>
    </div>
  `).join('');
}

function updateStats(data) {
  const prices = data.map(d => d.unitPrice).filter(p => p > 0);
  document.getElementById('s-count').textContent = data.length;
  document.getElementById('s-avg').textContent = prices.length ? (prices.reduce((a,b)=>a+b,0)/prices.length).toFixed(1) : '-';
  document.getElementById('s-hi').textContent = prices.length ? Math.max(...prices).toFixed(1) : '-';
  document.getElementById('s-lo').textContent = prices.length ? Math.min(...prices).toFixed(1) : '-';
}

function flyTo(lat, lng) {
  map.flyTo([lat, lng], 18, { duration: 0.8 });
  markerGroup.eachLayer(m => {
    if (Math.abs(m.getLatLng().lat - lat) < 0.0001 && Math.abs(m.getLatLng().lng - lng) < 0.0001) m.openPopup();
  });
}

function toggleLayer(name) {
  const info = layers[name];
  const el = document.getElementById('tog-' + name);
  if (name === 'markers') {
    info.active = !info.active; el.classList.toggle('on');
    info.active ? map.addLayer(markerGroup) : map.removeLayer(markerGroup);
    return;
  }
  info.active = !info.active; el.classList.toggle('on');
  info.active ? map.addLayer(info.layer) : map.removeLayer(info.layer);
}

function filterData(q) {
  q = q.toLowerCase();
  const filtered = allData.filter(d =>
    (d.section||'').toLowerCase().includes(q) ||
    (d.landNumber||'').toLowerCase().includes(q) ||
    (d.district||'').toLowerCase().includes(q)
  );
  createMarkers(filtered); renderCards(filtered); updateStats(filtered);
}

function loadData(data) {
  allData = data;
  createMarkers(data);
  renderCards(data);
  updateStats(data);
  // Fit bounds if multiple markers
  if (data.length > 1) {
    const validPts = data.filter(d => d.lat && d.lng && d.lat !== 0);
    if (validPts.length > 0) {
      const allPts = [[qLat, qLng], ...validPts.map(d => [d.lat, d.lng])];
      map.fitBounds(allPts, { padding: [50, 50], maxZoom: 16 });
    }
  }
  document.getElementById('loading').classList.remove('show');
}

// === 資料載入 ===
// 方式1: 從 URL 的 data 參數讀取 (Base64 encoded JSON)
const encodedData = params.get('data');
if (encodedData) {
  try {
    const decoded = JSON.parse(atob(encodedData));
    loadData(decoded.map(d => ({
      district: d['行政區'] || d.district || '',
      section: d['地段'] || d.section || '',
      landNumber: d['地號'] || d.landNumber || '',
      area: d['面積(坪)'] || d.area || '',
      totalPrice: d['總價(萬)'] || d.totalPrice || '',
      unitPrice: parseFloat(d['單價(萬)-住區單價'] || d.unitPrice || 0),
      zoning: d['分區'] || d.zoning || '',
      date: d['日期'] || d.date || '',
      lat: parseFloat(d.lat || 0),
      lng: parseFloat(d.lng || 0)
    })));
  } catch(e) { console.error('Data parse error:', e); }
}
// 方式2: 從 n8n Webhook API 拉資料
else if (apiUrl) {
  document.getElementById('loading').classList.add('show');
  fetch(apiUrl + '?lat=' + qLat + '&lng=' + qLng + '&district=' + encodeURIComponent(qDistrict) + '&section=' + encodeURIComponent(qSection))
    .then(r => r.json())
    .then(data => {
      loadData((data.nearby || data).map(d => ({
        district: d['行政區'] || d.district || '',
        section: d['地段'] || d.section || '',
        landNumber: d['地號'] || d.landNumber || '',
        area: d['面積(坪)'] || d.area || '',
        totalPrice: d['總價(萬)'] || d.totalPrice || '',
        unitPrice: parseFloat(d['單價(萬)-住區單價'] || d.unitPrice || 0),
        zoning: d['分區'] || d.zoning || '',
        date: d['日期'] || d.date || '',
        lat: parseFloat(d.lat || 0),
        lng: parseFloat(d.lng || 0)
      })));
    })
    .catch(e => { console.error('API error:', e); document.getElementById('loading').classList.remove('show'); });
}
// 方式3: 沒有參數，顯示空白地圖
else {
  loadData([]);
}
</script>
</body>
</html>
